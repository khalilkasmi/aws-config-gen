#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["boto3", "certifi"]
# ///
"""aws-config-gen: Interactive TUI to discover and generate ~/.aws/config from AWS SSO."""

import argparse
import concurrent.futures
import os
import re
import shutil
import subprocess
import sys
import time
import webbrowser

import boto3

# ── Colors ──────────────────────────────────────────────────────────
class C:
    BOLD = "\033[1m"
    DIM = "\033[2m"
    GREEN = "\033[32m"
    YELLOW = "\033[33m"
    CYAN = "\033[36m"
    RED = "\033[31m"
    RESET = "\033[0m"

def info(msg): print(f"{C.CYAN}{msg}{C.RESET}", file=sys.stderr)
def success(msg): print(f"{C.GREEN}{msg}{C.RESET}", file=sys.stderr)
def warn(msg): print(f"{C.YELLOW}{msg}{C.RESET}", file=sys.stderr)
def error(msg): print(f"{C.RED}{msg}{C.RESET}", file=sys.stderr)
def dim(msg): print(f"{C.DIM}{msg}{C.RESET}", file=sys.stderr)
def bold(msg): print(f"{C.BOLD}{msg}{C.RESET}", file=sys.stderr)


# ── SSO Region Detection ────────────────────────────────────────────
def detect_sso_region(sso_url: str) -> str | None:
    """Detect the SSO region by inspecting the portal's response headers.
    The Link header contains the SSO portal URL with the region embedded."""
    import ssl
    import urllib.request

    try:
        import certifi
        ctx = ssl.create_default_context(cafile=certifi.where())
    except Exception:
        ctx = ssl.create_default_context()

    # Try with default certs, then unverified as fallback (just reading headers)
    for ssl_ctx in [ctx, ssl._create_unverified_context()]:
        try:
            req = urllib.request.Request(sso_url, method="HEAD")
            resp = urllib.request.urlopen(req, context=ssl_ctx, timeout=10)
            link = resp.headers.get("Link", "")
            csp = resp.headers.get("Content-Security-Policy", "")
            for header_val in [link, csp]:
                match = re.search(r"portal\.sso\.([a-z0-9-]+)\.amazonaws\.com", header_val)
                if match:
                    return match.group(1)
        except ssl.SSLError:
            continue
        except Exception:
            break
    return None


# ── SSO Auth ────────────────────────────────────────────────────────
def get_access_token(sso_url: str, sso_region: str) -> str:
    oidc = boto3.client("sso-oidc", region_name=sso_region)

    info("Registering SSO client...")
    client = oidc.register_client(clientName="aws-config-gen", clientType="public")
    client_id = client["clientId"]
    client_secret = client["clientSecret"]

    info("Starting device authorization...")
    device_auth = oidc.start_device_authorization(
        clientId=client_id,
        clientSecret=client_secret,
        startUrl=sso_url,
    )

    device_code = device_auth["deviceCode"]
    user_code = device_auth.get("userCode", "")
    verification_uri = device_auth.get("verificationUriComplete") or device_auth.get("verificationUri", "")
    interval = device_auth.get("interval", 5) or 5

    if not verification_uri:
        error("Failed to get verification URI from SSO")
        error(f"Response: {device_auth}")
        sys.exit(1)

    print(file=sys.stderr)
    bold("Opening browser for SSO login...")
    dim(f"URL:  {verification_uri}")
    if user_code:
        dim(f"Code: {user_code}")
    print(file=sys.stderr)

    webbrowser.open(verification_uri)
    warn("Waiting for authorization (approve in browser)...")

    for attempt in range(120):
        time.sleep(interval)
        try:
            token = oidc.create_token(
                clientId=client_id,
                clientSecret=client_secret,
                grantType="urn:ietf:params:oauth:grant-type:device_code",
                deviceCode=device_code,
            )
            return token["accessToken"]
        except oidc.exceptions.AuthorizationPendingException:
            continue
        except oidc.exceptions.SlowDownException:
            interval += 1
            continue
        except Exception as e:
            error(f"Token error: {e}")
            sys.exit(1)

    error("Timed out waiting for authorization")
    sys.exit(1)


# ── Account/Role Discovery ─────────────────────────────────────────
def fetch_all_accounts(access_token: str, sso_region: str) -> list[dict]:
    sso = boto3.client("sso", region_name=sso_region)
    accounts = []
    paginator = sso.get_paginator("list_accounts")
    for page in paginator.paginate(accessToken=access_token):
        accounts.extend(page.get("accountList", []))
    return accounts


def fetch_roles_for_account(access_token: str, sso_region: str, account: dict) -> list[dict]:
    sso = boto3.client("sso", region_name=sso_region)
    acct_id = account["accountId"]
    acct_name = account.get("accountName", acct_id)
    acct_email = account.get("emailAddress", "")
    entries = []
    try:
        paginator = sso.get_paginator("list_account_roles")
        for page in paginator.paginate(accessToken=access_token, accountId=acct_id):
            for role in page.get("roleList", []):
                entries.append({
                    "account_id": acct_id,
                    "account_name": acct_name,
                    "email": acct_email,
                    "role_name": role["roleName"],
                })
    except Exception:
        pass  # skip accounts we can't list roles for
    return entries


def discover_roles(access_token: str, sso_region: str, accounts: list[dict]) -> list[dict]:
    entries = []
    with concurrent.futures.ThreadPoolExecutor(max_workers=10) as pool:
        futures = {
            pool.submit(fetch_roles_for_account, access_token, sso_region, acct): acct
            for acct in accounts
        }
        done = 0
        total = len(futures)
        for future in concurrent.futures.as_completed(futures):
            done += 1
            print(f"\r{C.DIM}  [{done}/{total}]{C.RESET}", end="", file=sys.stderr)
            entries.extend(future.result())
    print(file=sys.stderr)
    return entries


# ── Profile Naming ──────────────────────────────────────────────────
def sanitize(s: str) -> str:
    s = s.lower()
    s = re.sub(r"[^a-z0-9-]", "-", s)
    s = re.sub(r"-+", "-", s)
    return s.strip("-")


def make_profile_name(entry: dict, fmt: str) -> str:
    name = fmt
    name = name.replace("{account}", sanitize(entry["account_id"]))
    name = name.replace("{name}", sanitize(entry["account_name"]))
    name = name.replace("{email}", sanitize(entry["email"]))
    name = name.replace("{role}", sanitize(entry["role_name"]))
    return name


# ── TUI Selection (fzf) ────────────────────────────────────────────
def fzf_select(entries: list[dict], profile_format: str) -> list[dict]:
    if not shutil.which("fzf"):
        error("fzf is required for interactive selection. Install with: brew install fzf")
        error("Or use --select-all to skip the TUI.")
        sys.exit(1)

    lines = []
    for i, e in enumerate(entries):
        profile = make_profile_name(e, profile_format)
        line = f"{i}\t{e['account_name']:<40}  {e['account_id']:<14}  {e['role_name']:<30}  {profile}"
        lines.append(line)

    header = f"{'ACCOUNT NAME':<40}  {'ACCOUNT ID':<14}  {'ROLE':<30}  PROFILE NAME"
    input_text = "\n".join(lines)

    bold("Select profiles to add (TAB to toggle, ENTER to confirm):")

    try:
        result = subprocess.run(
            [
                "fzf", "--multi",
                "--header", header,
                "--prompt", "Filter > ",
                "--preview-window", "hidden",
                "--bind", "ctrl-a:select-all,ctrl-d:deselect-all",
                "--height", "80%",
                "--reverse",
                "--delimiter", "\t",
                "--with-nth", "2",
            ],
            input=input_text,
            capture_output=True,
            text=True,
        )
    except KeyboardInterrupt:
        warn("Cancelled.")
        sys.exit(0)

    if result.returncode != 0 or not result.stdout.strip():
        warn("No profiles selected. Exiting.")
        sys.exit(0)

    selected_indices = []
    for line in result.stdout.strip().split("\n"):
        idx = int(line.split("\t")[0])
        selected_indices.append(idx)

    return [entries[i] for i in selected_indices]


# ── Config Generation ──────────────────────────────────────────────
def generate_config(
    entries: list[dict],
    profile_format: str,
    sso_url: str,
    sso_region: str,
    region: str,
    output_format: str,
    sso_session: str | None,
) -> str:
    blocks = []

    if sso_session:
        blocks.append(
            f"[sso-session {sso_session}]\n"
            f"sso_start_url = {sso_url}\n"
            f"sso_region = {sso_region}\n"
            f"sso_registration_scopes = sso:account:access"
        )

    for entry in entries:
        profile = make_profile_name(entry, profile_format)
        block = (
            f"[profile {profile}]\n"
            f"sso_account_id = {entry['account_id']}\n"
            f"sso_role_name = {entry['role_name']}\n"
            f"region = {region}\n"
            f"output = {output_format}"
        )
        if sso_session:
            block += f"\nsso_session = {sso_session}"
        else:
            block += f"\nsso_start_url = {sso_url}\nsso_region = {sso_region}"
        blocks.append(block)

    return "\n\n".join(blocks) + "\n"


# ── Config Writing ─────────────────────────────────────────────────
def remove_existing_section(config_text: str, section_header: str) -> str:
    """Remove a section (from header to next header or EOF) from config text."""
    lines = config_text.split("\n")
    result = []
    skip = False
    for line in lines:
        if line.strip() == section_header:
            skip = True
            continue
        if line.startswith("[") and skip:
            skip = False
        if not skip:
            result.append(line)
    return "\n".join(result)


def write_config(
    config_output: str,
    config_file: str,
    new_file: bool,
    entries: list[dict],
    profile_format: str,
    sso_session: str | None,
):
    os.makedirs(os.path.dirname(config_file), exist_ok=True)

    if new_file:
        if os.path.exists(config_file):
            backup = f"{config_file}.bak.{int(time.time())}"
            shutil.copy2(config_file, backup)
            dim(f"Backed up existing config to {backup}")
        with open(config_file, "w") as f:
            f.write(config_output)
        success(f"Created {config_file}")
    else:
        existing = ""
        if os.path.exists(config_file):
            with open(config_file) as f:
                existing = f.read()

        # Remove duplicate profiles
        for entry in entries:
            profile = make_profile_name(entry, profile_format)
            header = f"[profile {profile}]"
            if header in existing:
                warn(f"Replacing existing profile: {profile}")
                existing = remove_existing_section(existing, header)

        # Remove duplicate sso-session
        if sso_session:
            session_header = f"[sso-session {sso_session}]"
            if session_header in existing:
                existing = remove_existing_section(existing, session_header)

        # Clean up trailing whitespace and append
        existing = existing.rstrip()
        if existing:
            existing += "\n\n"
        with open(config_file, "w") as f:
            f.write(existing + config_output)
        success(f"Appended to {config_file}")


# ── Main ───────────────────────────────────────────────────────────
def main():
    parser = argparse.ArgumentParser(
        prog="aws-config-gen",
        description="Interactive TUI to discover and generate ~/.aws/config from AWS SSO.",
    )
    parser.add_argument("--sso-url", required=True, help="SSO start URL")
    parser.add_argument("--region", default="eu-west-1", help="Default region (default: eu-west-1)")
    parser.add_argument("--sso-region", default=None, help="SSO region (defaults to --region)")
    parser.add_argument("--sso-session", default=None, help="SSO session name")
    parser.add_argument("--output", default="json", help="Output format (default: json)")
    parser.add_argument("--profile-format", default="{name}-{role}",
                        help="Profile naming: {name}, {account}, {role}, {email} (default: {name}-{role})")
    parser.add_argument("--new", action="store_true", help="Overwrite existing config (backs up first)")
    parser.add_argument("--dry-run", action="store_true", help="Print config to stdout only")
    parser.add_argument("--select-all", action="store_true", help="Skip TUI, select all profiles")
    parser.add_argument("--filter", default=None, help="Pre-filter accounts by pattern")

    args = parser.parse_args()
    sso_url = args.sso_url.rstrip("/")
    config_file = os.path.expanduser("~/.aws/config")

    # Auto-detect SSO region if not provided
    if args.sso_region:
        sso_region = args.sso_region
    else:
        info("Detecting SSO region...")
        detected = detect_sso_region(sso_url)
        if detected:
            sso_region = detected
            success(f"Detected SSO region: {sso_region}")
        else:
            sso_region = args.region
            warn(f"Could not detect SSO region, using: {sso_region}")

    # Authenticate
    access_token = get_access_token(sso_url, sso_region)
    success("Authenticated successfully.")
    print(file=sys.stderr)

    # Discover accounts
    info("Fetching accounts...")
    accounts = fetch_all_accounts(access_token, sso_region)
    success(f"Found {len(accounts)} accounts.")

    if not accounts:
        error("No accounts found. Check your SSO permissions.")
        sys.exit(1)

    # Discover roles (parallel)
    info("Fetching roles for each account...")
    entries = discover_roles(access_token, sso_region, accounts)
    success(f"Found {len(entries)} account/role combinations.")
    print(file=sys.stderr)

    if not entries:
        error("No roles found. Check your SSO permissions.")
        sys.exit(1)

    # Apply filter
    if args.filter:
        pattern = args.filter.lower()
        filtered = [e for e in entries if pattern in e["account_name"].lower()
                    or pattern in e["account_id"]
                    or pattern in e["role_name"].lower()]
        dim(f"Filter '{args.filter}' matched {len(filtered)}/{len(entries)} entries.")
        entries = filtered
        if not entries:
            error("No entries match filter.")
            sys.exit(1)

    # Sort by account name then role
    entries.sort(key=lambda e: (e["account_name"].lower(), e["role_name"].lower()))

    # Select
    if args.select_all:
        selected = entries
    else:
        selected = fzf_select(entries, args.profile_format)

    success(f"Selected {len(selected)} profiles.")
    print(file=sys.stderr)

    # Generate config
    config_output = generate_config(
        selected,
        args.profile_format,
        sso_url,
        sso_region,
        args.region,
        args.output,
        args.sso_session,
    )

    if args.dry_run:
        bold("── Generated Config ──")
        print(config_output)
        return

    write_config(config_output, config_file, args.new, selected, args.profile_format, args.sso_session)

    count = len(selected)
    success(f"Done! Added {count} profiles.")
    print(file=sys.stderr)
    dim(f"To login:  aws sso login --profile <profile-name>")
    dim(r"To list:   grep '^\[profile' ~/.aws/config")


if __name__ == "__main__":
    main()
